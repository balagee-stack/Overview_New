function convertTextToHTML(txt)
{
    var html = "";
    for (var x = 0; x < txt.paragraphs.length; x++)
    {

      var ranges = txt.paragraphs[x].textStyleRanges;

      for (var r = 0; r < ranges.length; r++)
      {
        if (ranges.length == 1)
        {
          try
          {
            var content = ranges[r].contents.match(txt.paragraphs[x].contents);
            if (content == null)
            {
              if (ranges[r].contents == txt.paragraphs[x].contents)
              {
                var content = txt.paragraphs[x].contents
              }
              else
              {
                var content = ranges[r].contents
              }
            }
          }
          catch (e)
          {
            if (content == null)
            {
              if (ranges[r].contents == txt.paragraphs[x].contents)
              {
                var content = txt.paragraphs[x].contents
              }
              else
              {
                var content = ranges[r].contents
              }
            }
          }
        }
        else if (r < ranges.length - 1)
        {
          var content = ranges[r].contents
        }
        else if (r == ranges.length - 1)
        {
          var c_index = txt.paragraphs[x].parent.characters.itemByRange(ranges[r].characters[0].index, txt.paragraphs[x].characters[-1].index)
          var content = ranges[r].contents.match(c_index.contents);
          if (content == null)
          {
            if (ranges[r].contents.toString() == c_index.contents.toString())
            {
              var content = c_index.contents
            }
            else
            {
              var content = c_index.contents
            }
          }
        }
        if (ranges[r].fontStyle.toLowerCase().match(/Bold italic/))
        {
          html += "<strong><em>" + content + "</em></strong>";
        }
        else if (ranges[r].fontStyle.toLowerCase().match(/italic/))
        {
            html += "<em>" + content + "</em>";
        }
        else if (ranges[r].fontStyle.toLowerCase().match(/bold/))
        {
          html += "<strong>" + content + "</strong>";
        }
        else
        {
            html += content;
        }
      }
    }

    return html;
}


