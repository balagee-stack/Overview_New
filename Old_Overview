function findGroups (mylabel, page)
{
    var group_frame = []
    for (var g = 0; g < doc.pages[page].groups.length; g++)
    {
        if (doc.pages[page].groups[g].label == mylabel)
        {
            group_frame.push(doc.pages[page].groups[g])
        }
    }
    group_frame.sort(function(a, b)
    {
        var aBounds = a.geometricBounds;
        var bBounds = b.geometricBounds;

        var aTop = aBounds[0];
        var bTop = bBounds[0];

        var aLeft = aBounds[1];
        var bLeft = bBounds[1];

        var rowTolerance = 20; 

        if (Math.abs(aTop - bTop) < rowTolerance)
        {
            return aLeft - bLeft; 
        }
        else
        {
            return aTop - bTop; 
        }
    });

    return group_frame;
}

